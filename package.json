{
  "name": "point-system",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "point-system",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "ui/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "installerIcon": "ui/icon.ico",
      "uninstallerIcon": "ui/icon.ico",
      "uninstallDisplayName": "point-system-uninstaller",
      "license": "license.md",
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": {
    "name": "Jessie Francisca",
    "email": "ciscajessie@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "electron-squirrel-startup": "1.0.1"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "24.13.3",
    "electron-reloader": "^1.2.3"
  },
  "overrides": {
    "electron-builder": {
      "@noble/hashes": "1.3.1"
    },
    "@noble/hashes": "1.3.1"
  }
}
